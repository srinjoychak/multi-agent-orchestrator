{
  "name": "multi-agent-orchestrator",
  "version": "0.1.0",
  "description": "Orchestrates multiple AI coding CLI agents (Claude Code, Gemini CLI) working as a team",
  "type": "module",
  "main": "src/orchestrator/index.js",
  "bin": {
    "orchestrate": "./src/orchestrator/index.js"
  },
  "scripts": {
    "start": "node src/mcp-server/index.js",
    "mcp": "node src/mcp-server/index.js",
    "build": "docker compose -f docker/docker-compose.yml build",
    "build:workers": "docker build -t worker-gemini -f docker/workers/Dockerfile.gemini . && docker build -t worker-claude -f docker/workers/Dockerfile.claude .",
    "validate": "bash docker/workers/validate-workers.sh",
    "test": "node --test src/**/*.test.js tests/**/*.test.js",
    "test:unit": "node --test src/**/*.test.js",
    "test:integration": "node --test tests/**/*.test.js"
  },
  "keywords": [
    "ai-agents",
    "multi-agent",
    "orchestrator",
    "claude-code",
    "gemini-cli",
    "agent-teams"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0"
  }
}
