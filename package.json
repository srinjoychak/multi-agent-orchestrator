{
  "name": "multi-agent-orchestrator",
  "version": "0.1.0",
  "description": "Orchestrates multiple AI coding CLI agents (Claude Code, Gemini CLI) working as a team",
  "type": "module",
  "main": "src/orchestrator/index.js",
  "bin": {
    "orchestrate": "./src/orchestrator/index.js"
  },
  "scripts": {
    "start": "node src/orchestrator/index.js",
    "orchestrate": "node src/orchestrator/index.js",
    "orchestrate:check": "node src/orchestrator/index.js --check-agents",
    "test": "node --test src/**/*.test.js tests/**/*.test.js",
    "test:unit": "node --test src/**/*.test.js",
    "test:integration": "node --test tests/**/*.test.js",
    "check-agents": "node src/adapters/check.js"
  },
  "keywords": [
    "ai-agents",
    "multi-agent",
    "orchestrator",
    "claude-code",
    "gemini-cli",
    "agent-teams"
  ],
  "license": "MIT"
}
