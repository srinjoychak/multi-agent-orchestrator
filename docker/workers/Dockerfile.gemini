FROM node:22-slim

# git: version control; procps: provides pgrep (required by gemini-cli internals)
RUN apt-get update && apt-get install -y --no-install-recommends git procps && rm -rf /var/lib/apt/lists/*

RUN npm install -g @google/gemini-cli@0.34.0

RUN mkdir -p /work /home/node/.gemini && \
    chown -R node:node /work /home/node/.gemini

# Pre-configure git identity so auto-commits work without interactive setup
RUN git config --global user.name "gemini-worker" && \
    git config --global user.email "gemini-worker@localhost" && \
    git config --global safe.directory '*'

USER node
WORKDIR /work

ENTRYPOINT ["gemini"]
